rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if a user is the creator of a wishlist
    function isCreator(wishlistId) {
      return request.auth != null && request.auth.uid == get(/databases/$(database)/documents/wishlists/$(wishlistId)).data.creatorId;
    }

    match /wishlists/{wishlistId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isCreator(wishlistId);

      match /wishes/{wishId} {
        allow read: if true;
        allow create, update, delete: if isCreator(wishlistId);
      }

      match /reservations/{wishId} {
        // Anyone can create a reservation (guests or anonymous users)
        allow create: if true;

        // Only the person who made the reservation (or potentially the creator of the list,
        // but we want it to be a surprise, so let's stick to the reserver) can update/delete it.
        // We added 'reservedByUid' in the frontend to support this.
        allow update, delete: if request.auth != null && (resource.data.reservedByUid == request.auth.uid);
        
        // Hide reservations from the creator to keep it a surprise!
        // Everyone else (guests) can read them to see what's already taken.
        allow read: if !isCreator(wishlistId);
      }
    }
  }
}
